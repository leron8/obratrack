PORT=3001

# Twilio WhatsApp sandbox
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_PARSING_MODEL=gpt-4o-mini

# Supabase (use Service Role key for the demo so inserts/selects work without RLS policies)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Demo company_id used by all requests (unless you pass `company_id` query/body).
DEFAULT_COMPANY_ID=00000000-0000-0000-0000-000000000001

# Default currency used by GPT if the transcript doesn't specify one.
DEFAULT_CURRENCY=MXN

